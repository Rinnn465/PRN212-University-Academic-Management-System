<Window x:Class="GUI.Views.Admin.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard"
        Height="480"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Admin Dashboard"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="WelcomeTextBlock"
                       FontSize="15"
                       Foreground="#52616B" />
        </StackPanel>
    </Grid>
</Window>

