<Window x:Class="GUI.Views.Lecturer.LecturerHomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lecturer Home"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource AppBackgroundBrush}"
          Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,22">
            <Button Content="Logout"
                    Style="{StaticResource DangerButtonStyle}"
                    DockPanel.Dock="Right"
                    Click="LogoutButton_Click" />
            <StackPanel>
                <TextBlock Text="Lecturer Home"
                           Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock x:Name="WelcomeTextBlock"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,18,0">
                <StackPanel>
                    <TextBlock Text="Lecturer Menu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />
                    <Button Content="Assigned Classes"
                            Style="{StaticResource MenuButtonStyle}" />
                    <Button Content="Student Grades"
                            Style="{StaticResource MenuButtonStyle}" />
                    <Button Content="Class Statistics"
                            Style="{StaticResource MenuButtonStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0">
                <StackPanel>
                    <TextBlock Text="Teaching Workspace"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Assigned subjects, grade entry, and class result statistics will be connected in Phase 6."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

