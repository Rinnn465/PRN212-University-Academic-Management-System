<Window x:Class="GUI.Views.Student.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI.Views.Student"
        mc:Ignorable="d"
        Title="My Profile"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Student Profile" 
                   FontSize="22" FontWeight="SemiBold" 
                   Margin="0,0,0,20" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Student Code:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Foreground="#52616B"/>
            <TextBox x:Name="txtStudentCode" IsReadOnly="True" VerticalContentAlignment="Center" 
                     Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="8,0" Background="#F5F5F5"/>

            <TextBlock Text="Full Name:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Foreground="#52616B"/>
            <TextBox x:Name="txtFullName" IsReadOnly="True" VerticalContentAlignment="Center" 
                     Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="8,0" Background="#F5F5F5"/>

            <TextBlock Text="Date of Birth:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Foreground="#52616B"/>
            <TextBox x:Name="txtDateOfBirth" IsReadOnly="True" VerticalContentAlignment="Center" 
                     Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="8,0" Background="#F5F5F5"/>

            <TextBlock Text="Email:" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Foreground="#52616B"/>
            <TextBox x:Name="txtEmail" IsReadOnly="True" VerticalContentAlignment="Center" 
                     Grid.Row="3" Grid.Column="1" Margin="0,5" Padding="8,0" Background="#F5F5F5"/>

            <TextBlock Text="Phone:" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" Foreground="#52616B"/>
            <TextBox x:Name="txtPhone" IsReadOnly="True" VerticalContentAlignment="Center" 
                     Grid.Row="4" Grid.Column="1" Margin="0,5" Padding="8,0" Background="#F5F5F5"/>

            <Button Content="Close" Grid.Row="5" Grid.Column="1" Width="100" Height="35" 
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                    Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
