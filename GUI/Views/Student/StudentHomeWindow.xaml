<Window x:Class="GUI.Views.Student.StudentHomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Home"
        Height="480"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Student Home"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="WelcomeTextBlock"
                       FontSize="15"
                       Foreground="#52616B" />
        </StackPanel>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="View Profile" 
                    Width="250" Height="45" FontSize="15" Margin="0,0,0,15" 
                    Click="BtnProfile_Click"/>

            <Button x:Name="BtnViewSubjects" 
                    Content="Subject Registration" Width="250" Height="45" FontSize="15" Margin="0,0,0,15" 
                    Click="BtnSubjectList_Click"/>
            

            <Button Content="View Grades &amp; GPA" 
                    Width="250" Height="45" FontSize="15" Margin="0,0,0,15" 
                    Click="BtnGrades_Click"/>

            <Button Content="Logout" 
                    Width="250" Height="45" FontSize="15" Margin="0,15,0,0" 
                    Background="#D9534F" Foreground="White" BorderBrush="Transparent"
                    Click="BtnLogout_Click"/>
        </StackPanel>
    </Grid>
</Window>

