<Window x:Class="GUI.Views.Student.SubjectRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI.Views.Student"
        mc:Ignorable="d"
        Title="Available Subjects" Height="450" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <DataGrid x:Name="dgSubjects" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding SubjectCode}" Width="100"/>
                <DataGridTextColumn Header="Name" Binding="{Binding SubjectName}" Width="*"/>
                <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="80"/>

                <DataGridTemplateColumn Header="Action" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Register" Click="BtnRegister_Click" Padding="5,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>