<Window x:Class="GUI.Views.Authentication.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="University Academic Management - Login"
        Height="420"
        Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Style="{StaticResource AuthPanelStyle}"
                Width="360">
            <StackPanel>
                <TextBlock Text="Academic Management"
                           Style="{StaticResource AuthTitleTextStyle}" />
                <TextBlock Text="Login"
                           Style="{StaticResource AuthSubtitleTextStyle}" />

                <TextBlock Text="Username"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}" />

                <TextBlock Text="Password"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource FormPasswordBoxStyle}"
                             KeyDown="PasswordBox_KeyDown" />

                <Button Content="Login"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click" />

                <Button Content="Create student account"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="RegisterButton_Click" />

                <TextBlock Text="{Binding Message}"
                           Style="{StaticResource ErrorTextStyle}" />

                <TextBlock Text="Demo accounts: admin / SE195001 / ThinhDP2 - password 12345"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,22,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

