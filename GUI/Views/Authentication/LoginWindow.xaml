<Window x:Class="GUI.Views.Authentication.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="University Academic Management - Login"
        Height="420"
        Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F4F6F8">
        <Border Width="360"
                Padding="28"
                Background="White"
                BorderBrush="#D9E0E7"
                BorderThickness="1"
                CornerRadius="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Academic Management"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           Margin="0,0,0,6" />
                <TextBlock Text="Login"
                           FontSize="15"
                           Foreground="#697586"
                           Margin="0,0,0,24" />

                <TextBlock Text="Username"
                           FontWeight="SemiBold"
                           Foreground="#344054"
                           Margin="0,0,0,6" />
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="36"
                         Padding="10,7"
                         Margin="0,0,0,14" />

                <TextBlock Text="Password"
                           FontWeight="SemiBold"
                           Foreground="#344054"
                           Margin="0,0,0,6" />
                <PasswordBox x:Name="PasswordBox"
                             Height="36"
                             Padding="10,7"
                             Margin="0,0,0,18"
                             KeyDown="PasswordBox_KeyDown" />

                <Button Content="Login"
                        Height="38"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="LoginButton_Click" />

                <TextBlock Text="{Binding Message}"
                           Foreground="#C0392B"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0" />

                <TextBlock Text="Demo accounts: admin / SE195001 / ThinhDP2 - password 12345"
                           Foreground="#697586"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,22,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

