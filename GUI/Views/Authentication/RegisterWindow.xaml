<Window x:Class="GUI.Views.Authentication.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="University Academic Management - Register"
        Height="620"
        Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Style="{StaticResource AuthPanelStyle}"
                Width="430">
            <StackPanel>
                <TextBlock Text="Academic Management"
                           Style="{StaticResource AuthTitleTextStyle}" />
                <TextBlock Text="Student registration"
                           Style="{StaticResource AuthSubtitleTextStyle}" />

                <TextBlock Text="Student code"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="StudentCodeTextBox"
                         Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}" />

                <TextBlock Text="Full name"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}" />

                <TextBlock Text="Gender"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <ComboBox SelectedValue="{Binding Gender, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="Content"
                          Style="{StaticResource FormComboBoxStyle}">
                    <ComboBoxItem Content="Nam" />
                    <ComboBoxItem Content="Nữ" />
                    <ComboBoxItem Content="Khác" />
                </ComboBox>

                <TextBlock Text="Email"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}" />

                <TextBlock Text="Phone"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}" />

                <TextBlock Text="Password"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource FormPasswordBoxStyle}" />

                <TextBlock Text="Confirm password"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Style="{StaticResource FormPasswordBoxStyle}"
                             KeyDown="ConfirmPasswordBox_KeyDown" />

                <Button Content="Register"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RegisterButton_Click"
                        Margin="0,4,0,0" />

                <Button Content="Back to login"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BackToLoginButton_Click" />

                <TextBlock Text="{Binding Message}"
                           Style="{StaticResource ErrorTextStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
